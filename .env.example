# 文档评审系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 通用配置 ====================
COMPOSE_PROJECT_NAME=doc-review-system
TZ=Asia/Shanghai

# ==================== PostgreSQL 配置 ====================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=docreview
POSTGRES_USER=docreview
POSTGRES_PASSWORD=your_secure_password_here

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ==================== MinIO 配置 ====================
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_BUCKET=doc-review

# ==================== 后端服务配置 ====================
BACKEND_PORT=8080
BACKEND_PROFILE=prod
# JWT 密钥 (请生成一个安全的随机字符串)
SA_TOKEN_TOKEN_NAME=satoken
SA_TOKEN_TIMEOUT=86400
SA_TOKEN_ACTIVE_TIMEOUT=-1
SA_TOKEN_IS_CONCURRENT=true
SA_TOKEN_IS_SHARE=true
SA_TOKEN_TOKEN_STYLE=uuid
SA_TOKEN_IS_LOG=true

# ==================== 前端服务配置 ====================
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080

# ==================== AD 域配置 (可选) ====================
AD_ENABLED=false
AD_URL=ldap://ad.example.com:389
AD_BASE_DN=dc=example,dc=com
AD_USERNAME=cn=admin,dc=example,dc=com
AD_PASSWORD=your_ad_password

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_PATH=/var/log/doc-review

# ==================== 备份配置 ====================
BACKUP_PATH=/backup
BACKUP_RETENTION_DAYS=7
